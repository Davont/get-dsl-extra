{
  "manifest_version": 3,
  "name": "Get DSL Extra",
  "version": "1.0.0",
  "description": "通过口令获取并下载 DSL 文件",
  "permissions": ["scripting"],
  "host_permissions": ["*://*.huawei.com/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  }
}
