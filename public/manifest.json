{
  "manifest_version": 3,
  "name": "Get DSL Extra",
  "version": "1.0.0",
  "description": "通过口令获取并下载 DSL 文件",
  "permissions": ["downloads", "activeTab"],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
